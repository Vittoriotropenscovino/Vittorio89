{
  "expo": {
    "name": "TravelSphere",
    "slug": "travelsphere",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelsphere.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find places on the globe.",
        "NSPhotoLibraryUsageDescription": "We need access to your photos to add memories to your trips."
      }
    },
    "android": {
      "package": "com.travelsphere.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "TravelSphere needs access to your photos to add memories to trips.",
          "cameraPermission": "TravelSphere needs access to your camera to capture moments."
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow TravelSphere to use Face ID for app lock."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "61fc099f-2081-4f30-8791-b01c20b0c5a5"
      }
    }
  }
}